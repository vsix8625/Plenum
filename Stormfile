cc: /usr/bin/gcc
cflags: -Wall -Wextra -Werror -std=c23

print: __sk_version__
if(__sk_version_minor__ <= 8)
{
    exit: "Requires sk version 0.8.x or latest"
}

if(run_tests){
    target test_ctor
    {
        kind: test
        cflags::
            -ggdb

        defines:
            -DDEBUG
            -DPL_USE_CONSTRUCTOR

        sources:
            core/
            test/test_ctor.c

        includes:
            -I.
            -Iinclude
    }

    target test_arena
    {
        kind: test
        cflags:: -ggdb

        defines: -DDEBUG

        sources:
            core/
            test/arena.c

        includes:
            -I.
            -Iinclude
    }

    target test-init
    {
        kind: test

        cflags::  -ggdb
        defines: -DDEBUG

        sources:
            core/
            test/test-init.c

        includes:
            -I.
            -Iinclude
    }

    target test_thread
    {
        kind: test
        cflags::
            -ggdb

        defines:
            -DDEBUG
            -DPL_USE_CONSTRUCTOR

        sources:
            core/
            test/test_thread.c

        includes:
            -I.
            -Iinclude
    }

    target test_gfx
    {
        kind: test
        cflags::
            -ggdb
        lflags:
            -lSDL3
            -pthread

        defines:
            -DDEBUG
            -DPL_USE_CONSTRUCTOR

        sources:
            core/
            gfx/
            test/test_gfx.c

        includes:
            -I.
            -Igfx
            -Iinclude
    }
}


target plenum-debug
{
    linker: mold
    kind: static

    cflags::
        -ggdb
        -pthread
    defines:
        -DDEBUG

    sources:
        core/

    includes:
        -Icore
        -Iinclude

    if(gui)
    {
        defines::
            -DPL_USE_GFX
            -DPL_USE_GUI
        sources::
            gfx/
            gui/
        includes::
            -Igfx
            -Igui
    }
    else if(gfx)
    {
        defines::
            -DPL_USE_GFX
        sources::
            gfx/
        includes::
            -Igfx
    }
}
