cc: /usr/bin/gcc
cflags: -Wall -Wextra -Werror -std=c23

print: __sk_version__
if(__sk_version_minor__ <= 8)
{
    exit: "Requires sk version 0.8.x or latest"
}

major: 0
minor: 1
micro: 1

codegen include/pl_config.h
{
    literal: "#pragma once"
    define: PL_VERSION_MAJOR major
    define: PL_VERSION_MINOR minor
    define: PL_VERSION_MICRO micro

    define: PL_VERSION_STR "major.minor.micro"
}

if(run_tests){
    target test_ctor
    {
        kind: test
        cflags::
            -ggdb

        defines:
            -DDEBUG
            -DPL_USE_CONSTRUCTOR

        sources:
            core/
            test/test_ctor.c

        includes:
            -I.
            -Iinclude
    }

    target test_thread
    {
        kind: test
        cflags::
            -ggdb

        defines:
            -DDEBUG
            -DPL_USE_CONSTRUCTOR

        sources:
            core/
            test/test_thread.c

        includes:
            -I.
            -Iinclude
    }

    target test_ui
    {
        kind: test
        cflags::
            -ggdb
        lflags:
            -lSDL3
            -pthread

        defines:
            -DDEBUG
            -DPL_USE_CONSTRUCTOR
            -DPL_USE_UI

        sources:
            core/
            ui/
            test/test_ui.c

        includes:
            -I.
            -Iui
            -Iinclude
    }
}


target plenum-debug
{
    linker: mold
    kind: static

    cflags::
        -ggdb
        -pthread
    defines:
        -DDEBUG

    sources:
        core/

    includes:
        -Icore
        -Iinclude

    if(ui)
    {
        sources::
            ui/
        includes::
            -Iui
    }
}
