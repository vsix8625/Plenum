cc: /usr/bin/gcc
cflags: -Wall -Wextra -Werror -std=c23

if(__sk_version_minor__ <= 8){
    exit: "Requires sk version 0.8.x or latest"
}

if(run_tests){

    target test_arena
    {
        kind: test
        cflags:: -ggdb

        defines: -DDEBUG

        sources:
            src/
            test/arena.c

        includes:
            -I.
            -Iinclude
    }

    target test-init
    {
        kind: test

        cflags::  -ggdb
        defines: -DDEBUG

        sources:
            src/
            test/test-init.c

        includes:
            -I.
            -Iinclude
    }
}

target plenum-debug
{
    print: __sk_version__
    kind: static

    cflags::  -ggdb
    defines: -DDEBUG

    sources:
        src/

    includes:
        -I.
        -Iinclude
}
